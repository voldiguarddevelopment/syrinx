# Syrinx — one-run test config. Copy to `scripts/test-all.env` and fill in the
# paths to the weights + parity fixtures on THIS machine (the model box).
#
#   cp scripts/test-all.env.example scripts/test-all.env
#   $EDITOR scripts/test-all.env
#   ./scripts/test-all.sh
#
# Any group whose vars are left unset is SKIPPED (its tests self-skip), so you can
# fill in only what you have and the runner reports the rest as SKIP, never FAIL.
# Paths below are the conventional box layout — adjust to yours.

# ============================ CosyVoice2 (CV2) ==============================
export SYRINX_LM_WEIGHTS=/root/models/CosyVoice2-0.5B/llm_fp32.safetensors
export SYRINX_LM_REF=/root/parity/lm/ref.safetensors
export SYRINX_LMGEN_REF=/root/parity/lmgen/ref.safetensors
export SYRINX_FLOW_WEIGHTS=/root/models/CosyVoice2-0.5B/flow_fp32.safetensors
export SYRINX_FLOW_REF=/root/parity/flow/ref.safetensors
export SYRINX_HIFT_WEIGHTS=/root/models/CosyVoice2-0.5B/hift_fp32.safetensors
export SYRINX_HIFT_REF=/root/parity/hift/ref.safetensors
export SYRINX_SPK_WEIGHTS=/root/models/CosyVoice2-0.5B/campplus_fp32.safetensors
export SYRINX_SPK_REF=/root/parity/spk/ref.safetensors
export SYRINX_TOK_JSON=/root/models/CosyVoice2-0.5B/tokenizer.json
export SYRINX_TOK_REF=/root/parity/tok/ref.safetensors
export SYRINX_STOK_ONNX=/root/models/CosyVoice2-0.5B/speech_tokenizer_v2.onnx
export SYRINX_STOK_REF=/root/parity/stok/ref.safetensors
export SYRINX_FEAT_REF=/root/parity/feat/ref.safetensors
export SYRINX_TEXTNORM_REF=/root/parity/textnorm/ref.safetensors
export SYRINX_E2E_REF=/root/parity/e2e/ref.safetensors
export SYRINX_QUANT=1                       # int4 footprint A/B
export SYRINX_EVAL_REF_WAV=/root/refs/voice_zh.wav
export SYRINX_EVAL_REF_WAV_EN=/root/refs/voice_en.wav
export SYRINX_EVAL_PROMPT_TEXT_EN="the reference transcript in english"

# ============================ CosyVoice3 (CV3) ==============================
export SYRINX_CV3_LM_WEIGHTS=/root/models/Fun-CosyVoice3-0.5B-2512/llm_fp32.safetensors
export SYRINX_CV3_LM_REF=/root/parity-cv3/lm/ref.safetensors
export SYRINX_CV3_FLOW_WEIGHTS=/root/models/Fun-CosyVoice3-0.5B-2512/flow_fp32.safetensors
export SYRINX_CV3_FLOW_REF=/root/parity-cv3/flow/ref.safetensors
export SYRINX_CV3_HIFT_WEIGHTS=/root/models/Fun-CosyVoice3-0.5B-2512/hift_fp32.safetensors
export SYRINX_CV3_HIFT_REF=/root/parity-cv3/hift/ref.safetensors
export SYRINX_CV3_SPK_WEIGHTS=/root/models/Fun-CosyVoice3-0.5B-2512/campplus_fp32.safetensors
export SYRINX_CV3_TOK_JSON=/root/models/Fun-CosyVoice3-0.5B-2512/tokenizer.json
export SYRINX_CV3_STOK_ONNX=/root/models/Fun-CosyVoice3-0.5B-2512/speech_tokenizer_v3.onnx
export SYRINX_CV3_STOK_REF=/root/parity-cv3/stok/ref.safetensors
export SYRINX_CV3_E2E_REF=/root/parity-cv3/e2e/ref.safetensors
export SYRINX_CV3_QUANT=1

# ============================ Fish Audio (s1-mini / s2-pro) =================
# Pure-Rust port targets. Weights via:  ./scripts/test-all.sh --download-fish
# s1-mini (0.5B, gated — needs `hf auth login`):
export SYRINX_FISH_S1_DIR=/root/models/openaudio-s1-mini
export SYRINX_FISH_S1_REF=/root/parity-fish/s1/ref.safetensors
# s2-pro (5B, public; needs int4 to fit a 12 GB GPU — parity on CPU/bf16 or >=16 GB):
export SYRINX_FISH_S2_DIR=/root/models/s2-pro
export SYRINX_FISH_S2_REF=/root/parity-fish/s2/ref.safetensors
export SYRINX_FISH_S2_INT4=1                # functional int4 run on a 12 GB card

# ============================ speech-to-text (Whisper) =====================
# Pure-Rust/Candle Whisper (crates/syrinx-stt): the reverse path (audio->text) and
# the NATIVE TTS-intelligibility oracle (transcribe a synth output, score WER).
# Download a model (tiny/base/small/medium/large-v3):
#   hf download openai/whisper-base --local-dir /root/models/whisper-base
export SYRINX_STT_MODEL_DIR=/root/models/whisper-base
export SYRINX_STT_WAV=/root/refs/voice_en.wav
export SYRINX_STT_REF="the reference transcript of the test clip"
export SYRINX_STT_LANG=en                    # optional: force language (else auto)
export SYRINX_STT_WER_MAX=0.5                # optional: max acceptable WER

# ============================ eval helpers (optional) ======================
# Leave unset to report WER/MOS as honest nulls instead of measuring them.
export SYRINX_WER_HELPER="micromamba run -n syrinx python scripts/eval_wer.py"
export SYRINX_MOS_HELPER="micromamba run -n syrinx python scripts/eval_mos.py"
